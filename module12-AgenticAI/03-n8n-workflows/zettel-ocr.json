    {
      "parameters": {
        "jsCode": "\nlet execId = $execution.id;\nlet text = `🧾 **Neuer Kassenbon erkannt!**\\n`;\nlet total = 0;\nlet html = `<h2>Kassenbon korrigieren</h2>\n  <form action=\">>>WEBHOOK EINSETZEN<<<\" method=\"POST\">\n  <input type=\"hidden\" name=\"receipt_id\" value=\"${execId}\">`\n\nfor (let i = 0; i < $input.first().json.output.length; i++) {\n  let item = $input.first().json.output[i];\n  const addText = `\n🛒 **${item.item}**\n💶 ${item.cost} € | 🏷️ ${item.category}\n`\n  text += addText\n  total += item.cost\n\n  html += `<div style=\"margin-bottom: 10px;\">\n      <input type=\"text\" name=\"item_${i}\" value=\"${item.item}\">\n      <input type=\"number\" step=\"0.01\" name=\"cost_${i}\" value=\"${item.cost}\">\n      <input type=\"text\" name=\"category_${i}\" value=\"${item.category}\">\n    </div>`;\n}\n\nhtml += `<button type=\"submit\">Änderungen speichern</button></form>`;\n\nreturn {text, total, html}"
      },
